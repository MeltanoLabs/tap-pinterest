# Pinterest Tap Configuration
# Copy this file to .env and fill in your actual values.

# API URL — override for sandbox testing
# TAP_PINTEREST_API_URL=https://api-sandbox.pinterest.com/v5

# Option 1: Direct access token (sandbox or short-lived token, no refresh)
# TAP_PINTEREST_ACCESS_TOKEN=pina_...

# Option 2: Standard OAuth2 credentials (client ID + secret + refresh token)
TAP_PINTEREST_CLIENT_ID=your_client_id_here
TAP_PINTEREST_CLIENT_SECRET=your_client_secret_here
TAP_PINTEREST_REFRESH_TOKEN=your_refresh_token_here

# Option 3: Meltano Cloud proxy OAuth (no client ID/secret required)
# TAP_PINTEREST_OAUTH_CREDENTIALS__REFRESH_PROXY_URL=https://your-proxy-url/oauth/token
# TAP_PINTEREST_OAUTH_CREDENTIALS__REFRESH_PROXY_URL_AUTH=Bearer your_proxy_auth_token
# TAP_PINTEREST_OAUTH_CREDENTIALS__REFRESH_TOKEN=your_refresh_token_here
# TAP_PINTEREST_OAUTH_CREDENTIALS__ACCESS_TOKEN=your_access_token_here  # optional

# Optional: Date range for analytics streams (YYYY-MM-DD).
# Defaults to the last 30 days. Pinterest limits analytics to 90 days per request.
TAP_PINTEREST_START_DATE=2024-01-01
TAP_PINTEREST_END_DATE=2024-01-31

# Optional: Metric columns to fetch for analytics streams (JSON array).
# Defaults to a standard set of spend, impression, click, and engagement metrics.
# TAP_PINTEREST_ANALYTICS_COLUMNS=["SPEND_IN_DOLLAR","PAID_IMPRESSION","TOTAL_CLICKTHROUGH"]

# Optional: Time granularity for analytics streams.
# One of: TOTAL, DAY, HOUR, WEEK, MONTH. Defaults to DAY.
# TAP_PINTEREST_ANALYTICS_GRANULARITY=DAY
